template<typename T>
void print_vector(const vector<T>& elems) {
    for (int i = 0; i < elems.size(); i += 1) {
        cout << elems[i] << endl;
    }
}

void print_array(const int array[], const int SIZE) {
    for (int i = 0; i < SIZE; i += 1) {
        cout << array[i] << endl;
    }
}

